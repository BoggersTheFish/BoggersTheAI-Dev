# ================================================================
# BoggersTheFish Site — Environment Variables
# Copy this file to .env.local and fill in values
# ================================================================

# GitHub API Token (for live repo data in Wave 5 — Projects)
# Generate at: https://github.com/settings/tokens
GITHUB_TOKEN=your_github_personal_access_token_here

# Public site URL
NEXT_PUBLIC_SITE_URL=https://boggersthefish.com

# Wave Configuration
NEXT_PUBLIC_WAVE_CYCLE_INTERVAL_MS=30000
NEXT_PUBLIC_CURRENT_WAVE=12
NEXT_PUBLIC_WAVE_NAME="Pages Island LIVE"
NEXT_PUBLIC_LAST_WAVE_DATE=2026-03-21

# BoggersTheAI — browser calls this base (default: Next proxy /api/boggers → FastAPI)
NEXT_PUBLIC_BOGGERS_API_BASE=/api/boggers

# Server-side only (Next Route Handler proxy — never NEXT_PUBLIC_)
BOGGERS_INTERNAL_URL=http://127.0.0.1:8000
BOGGERS_DASHBOARD_TOKEN=

# Legacy names (optional)
BOGGERSTHEAI_API_URL=http://localhost:8000
BOGGERSTHEAI_API_KEY=your_api_key_here
