# Copy this file to .env and fill in values locally.
# Do not commit your real .env file.

# X/Twitter adapter (optional)
X_API_KEY=
X_API_SECRET=
X_BEARER_TOKEN=

# Optional remote inference fallback
INFERENCE_API_KEY=
INFERENCE_BASE_URL=

# FastAPI dashboard (optional)
# If BOGGERS_DASHBOARD_TOKEN is set, /status, /graph, /metrics, /traces require:
#   Authorization: Bearer <token>
# Leave empty for local-only open access (a warning is logged if unset).
BOGGERS_DASHBOARD_TOKEN=
# Default in code is 127.0.0.1 (loopback). Use 0.0.0.0 only if you need LAN access.
BOGGERS_DASHBOARD_HOST=127.0.0.1
BOGGERS_DASHBOARD_PORT=8000

# If set to 1 or true, config validation raises on warnings (strict mode).
# BOGGERS_CONFIG_STRICT=1
