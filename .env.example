# Copy to .env and adjust. Used by docker compose.
COMPOSE_PROJECT_NAME=ts-os

# Strong random value in production (protects /status, /graph, /query, etc.)
BOGGERS_DASHBOARD_TOKEN=

# Comma-separated origins for FastAPI CORS (browser → backend when not using Next proxy)
BOGGERS_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Caddy (docker compose --profile tls): hostname or :80 block label
CADDY_DOMAIN=localhost

# Optional: for Caddy ACME registration
CADDY_ADMIN_EMAIL=

# Wave 13 — Distributed Graph (logical coordinator API)
BOGGERS_DISTRIBUTED_ENABLED=0
BOGGERS_SHARD_COUNT=4
BOGGERS_GLOBAL_MAX_NODES=100000
BOGGERS_PER_SHARD_MAX_NODES=25000

# Wave 13 — Multi-agent (Redis in compose)
REDIS_URL=redis://redis:6379/0
